# Server runtime
NODE_ENV=development
PORT=4000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/saan

# Redis connection string (sessions, rate limiting, cart cache)
# Local: redis://localhost:6379
# Upstash: rediss://default:<token>@<host>.upstash.io:6379 (TLS required — use rediss://)
REDIS_URL=redis://localhost:6379

# JWT secrets — must be at least 32 characters; rotate via env change in production
JWT_ACCESS_SECRET=change-me-to-a-secure-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-secure-refresh-secret-min-32-chars

# JWT token lifetimes (e.g. 15m, 7d)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated list of allowed browser origins for CORS.
# With the Next.js /api rewrite proxy, browsers only talk to the frontend origin;
# keep this list to your frontend URL(s). Server-to-server proxy requests carry
# no Origin header and are allowed automatically.
# Local: http://localhost:3000  |  Prod: https://saan.com
CORS_ORIGINS=http://localhost:3000

# Frontend base URL used to build password-reset links in emails
APP_URL=http://localhost:3000

# bcrypt cost factor (minimum 12 per security rules)
BCRYPT_ROUNDS=12

# Set to true in production so refresh-token cookies are HTTPS-only
COOKIE_SECURE=false

# lax | strict | none — use lax with the Next.js /api proxy (first-party cookies).
# Only use none if the browser still calls the API on a different domain directly.
COOKIE_SAME_SITE=lax

# Name of the httpOnly refresh-token cookie
REFRESH_TOKEN_COOKIE_NAME=saan_refresh_token

# Name of the readable CSRF double-submit cookie (paired with X-CSRF-Token header)
CSRF_TOKEN_COOKIE_NAME=saan_csrf_token

# OTP and password-reset token expiry windows (minutes)
OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_EXPIRY_MINUTES=30

# SMTP settings for transactional email (nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM_NAME=SAAN
EMAIL_FROM_ADDRESS=noreply@saan.example

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Razorpay payment gateway (Test mode keys from Razorpay Dashboard)
# Optional in development/test — placeholder defaults allow the server to boot.
# In production: KEY_ID + KEY_SECRET required. WEBHOOK_SECRET required only for live keys.
# Set RAZORPAY_TEST_MODE=true (or use rzp_test_* KEY_ID) to skip webhook secret in production.
RAZORPAY_TEST_MODE=true
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Cloudinary image uploads (required — exact variable names below)
# Cloudinary Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=saan/products
# Do NOT use CLOUD_NAME / CLOUD_API_KEY — those are ignored unless the CLOUDINARY_* vars are missing

# -----------------------------------------------------------------------------
# Vercel deployment checklist
# - **Recommended:** Vercel project → Settings → General → Root Directory = `server`
#   (then only `server/vercel.json` is used)
# - If Root Directory is empty (repo root), the root `vercel.json` routes to `server/api`
# - Add every variable above in Vercel → Settings → Environment Variables
#   (logs showing "injected env (0)" mean no vars are set — the function will crash)
# - REDIS_URL must use rediss:// for Upstash
# - CORS_ORIGINS must include your frontend URL (e.g. https://saan.com)
# - APP_URL must be your frontend URL (password-reset emails)
# - COOKIE_SECURE=true and COOKIE_SAME_SITE=lax when using the Next.js /api proxy
# - MongoDB Atlas: allow access from 0.0.0.0/0 (or Vercel IPs)
# - CLOUDINARY_* required in production for product image uploads
