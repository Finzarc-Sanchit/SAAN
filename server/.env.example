# Server runtime
NODE_ENV=development
PORT=4000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/saan

# Redis connection string (sessions, rate limiting, cart cache)
# Local: redis://localhost:6379
# Upstash: rediss://default:<token>@<host>.upstash.io:6379 (TLS required — use rediss://)
REDIS_URL=redis://localhost:6379

# JWT secrets — must be at least 32 characters; rotate via env change in production
JWT_ACCESS_SECRET=change-me-to-a-secure-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-secure-refresh-secret-min-32-chars

# JWT token lifetimes (e.g. 15m, 7d)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:3000

# Frontend base URL used to build password-reset links in emails
APP_URL=http://localhost:3000

# bcrypt cost factor (minimum 12 per security rules)
BCRYPT_ROUNDS=12

# Set to true in production so refresh-token cookies are HTTPS-only
COOKIE_SECURE=false

# strict | lax | none — use none when frontend and API are on different domains
COOKIE_SAME_SITE=strict

# Name of the httpOnly refresh-token cookie
REFRESH_TOKEN_COOKIE_NAME=saan_refresh_token

# OTP and password-reset token expiry windows (minutes)
OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_EXPIRY_MINUTES=30

# SMTP settings for transactional email (nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM_NAME=SAAN
EMAIL_FROM_ADDRESS=noreply@saan.example

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Vercel deployment checklist
# - **Recommended:** Vercel project → Settings → General → Root Directory = `server`
#   (then only `server/vercel.json` is used)
# - If Root Directory is empty (repo root), the root `vercel.json` routes to `server/api`
# - Add every variable above in Vercel → Settings → Environment Variables
#   (logs showing "injected env (0)" mean no vars are set — the function will crash)
# - REDIS_URL must use rediss:// for Upstash
# - CORS_ORIGINS must include your frontend URL (e.g. https://your-app.vercel.app)
# - APP_URL must be your frontend URL (password-reset emails)
# - COOKIE_SECURE=true and COOKIE_SAME_SITE=none if client and API are on different domains
# - MongoDB Atlas: allow access from 0.0.0.0/0 (or Vercel IPs)
