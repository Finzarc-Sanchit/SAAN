# =============================================================================
# SAAN Client — environment variables
# Copy to `.env.local` for local development (Next.js loads it automatically).
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API (server-side only — never prefixed with NEXT_PUBLIC_)
# Direct origin of the Express server. Next.js rewrites /api/* to this host.
# Must match server PORT (see server/.env).
# Local: http://localhost:8000  |  Prod: https://your-api.onrender.com
# -----------------------------------------------------------------------------
BACKEND_ORIGIN=http://localhost:8000

# -----------------------------------------------------------------------------
# Sanity CMS — https://www.sanity.io/manage
# Required for shop content, campaigns, and /studio.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: read token for private datasets or draft preview (server-side only).
# Create at Sanity → Project → API → Tokens (Viewer or Editor).
SANITY_API_READ_TOKEN=
